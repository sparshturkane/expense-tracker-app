{
  "expo": {
    "name": "expense-tracker-app",
    "slug": "expense-tracker-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "expense-tracker",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expensetracker.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to scan QR codes for sharing expense data with friends.",
        "NSLocalNetworkUsageDescription": "This app uses the network to sync expense data with other devices."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET"
      ],
      "package": "com.expensetracker.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow expense-tracker to access your camera for scanning QR codes."
        }
      ],
      "expo-router"
    ]
  }
}
